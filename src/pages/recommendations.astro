---
import BaseLayout from '../layouts/BaseLayout.astro';

import books from '../content/recommendations/books.json';
import movies from '../content/recommendations/movies.json';
import quotes from '../content/recommendations/quotes.json';
---

<BaseLayout title="Recommendations — Lancelot" description="Books, movies, and quotes I recommend">
  <main id="main-content" class="container">
    <article class="page-content">
      <h1>Recommendations</h1>

      <section class="rec-section">
        <h2>Quotes</h2>
        <ul class="rec-list">
          {quotes.map((q) => (
            <li>
              <span class="quote-text">&ldquo;{q.text}&rdquo;</span>
              <span class="quote-dash">&mdash;</span>
              <span class="rec-meta">{q.author}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="rec-section">
        <h2>Books</h2>
        <ul class="rec-list">
          {books.map((b) => (
            <li>
              <a href={b.link} target="_blank" rel="noopener noreferrer" class="rec-title">{b.title}</a>
              <span class="rec-meta">{b.author}</span>
              {b.status === 'read' && <span class="status-done">read</span>}
              {b.status === 'reading' && <span class="status-reading">reading</span>}
            </li>
          ))}
        </ul>
      </section>

      <section class="rec-section">
        <h2>Movies</h2>
        <ul class="rec-list">
          {movies.map((m) => (
            <li>
              <span class="rec-title">{m.title}</span>
              <span class="rec-meta">({m.year})</span>
              {m.status === 'watched' && <span class="status-done">watched</span>}
            </li>
          ))}
        </ul>
      </section>
    </article>
  </main>
</BaseLayout>

<style>
  .page-content {
    padding: 3rem 0;
  }

  .page-content h1 {
    font-size: 1.8rem;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
  }

  .rec-section {
    margin-bottom: 2.5rem;
  }

  .rec-list {
    list-style: none;
  }

  .rec-list li {
    padding: 0.4rem 0;
    font-size: 0.95rem;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .rec-title {
    font-weight: 600;
  }

  .rec-meta {
    color: var(--color-text-light);
    font-size: 0.9rem;
  }

  .quote-text {
    font-style: italic;
  }

  .quote-dash {
    color: var(--color-text-light);
  }

  .status-done {
    font-size: 0.75rem;
    color: #3a7d44;
    margin-left: auto;
  }

  .status-reading {
    font-size: 0.75rem;
    color: #b08520;
    margin-left: auto;
  }
</style>
