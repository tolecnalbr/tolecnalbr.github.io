---
const farmerSrc = `${import.meta.env.BASE_URL}knight-placeholder.svg`;
---

<div id="farmer-intro" class="farmer-intro">
  <div id="farmer" class="farmer">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 28 36" width="112" height="144" style="image-rendering: pixelated;">
      <!-- Pixel art farmer SIDE PROFILE - facing left, with pitchfork -->

      <g id="farmer-upper">
        <!-- === HAT (thicker) === -->
        <rect x="1" y="2" width="16" height="1" fill="#D4A857"/>
        <rect x="2" y="3" width="14" height="1" fill="#C4983E"/>
        <rect x="5" y="0" width="8" height="1" fill="#C4983E"/>
        <rect x="4" y="1" width="10" height="1" fill="#D4A857"/>
        <rect x="4" y="2" width="10" height="1" fill="#D4A857"/>
        <rect x="4" y="3" width="10" height="1" fill="#8B6914"/>

        <!-- === HAIR === -->
        <rect x="13" y="4" width="2" height="3" fill="#2C1810"/>
        <rect x="4" y="4" width="1" height="2" fill="#2C1810"/>

        <!-- === HEAD === -->
        <rect x="5" y="4" width="8" height="1" fill="#E8B88A"/>
        <rect x="4" y="5" width="9" height="1" fill="#E8B88A"/>
        <rect x="3" y="6" width="10" height="1" fill="#E8B88A"/>
        <rect x="4" y="7" width="9" height="1" fill="#E8B88A"/>
        <rect x="5" y="8" width="7" height="1" fill="#E8B88A"/>
        <!-- Eye -->
        <rect x="6" y="5" width="2" height="1" fill="#1a1a1a"/>
        <!-- Nose -->
        <rect x="3" y="6" width="1" height="1" fill="#D4A070"/>
        <!-- Mouth -->
        <rect x="4" y="7" width="1" height="1" fill="#C4946A"/>

        <!-- === STRAW === -->
        <rect x="0" y="7" width="4" height="1" fill="#D4A857"/>

        <!-- === NECK === -->
        <rect x="8" y="9" width="4" height="1" fill="#E8B88A"/>

        <!-- === SHIRT === -->
        <rect x="7" y="10" width="6" height="1" fill="#E8C840"/>
        <rect x="7" y="11" width="6" height="1" fill="#D4B030"/>

        <!-- === ARM === -->
        <rect x="5" y="10" width="2" height="1" fill="#E8C840"/>
        <rect x="4" y="11" width="2" height="1" fill="#E8C840"/>
        <rect x="3" y="12" width="2" height="1" fill="#E8B88A"/>

        <!-- === PITCHFORK === -->
        <!-- Handle -->
        <rect x="3" y="13" width="1" height="1" fill="#8B4513"/>
        <rect x="2" y="14" width="1" height="1" fill="#8B4513"/>
        <rect x="2" y="15" width="1" height="1" fill="#6B3410"/>
        <rect x="1" y="16" width="1" height="1" fill="#6B3410"/>
        <rect x="1" y="17" width="1" height="1" fill="#8B4513"/>
        <rect x="0" y="18" width="1" height="1" fill="#8B4513"/>
        <!-- Crossbar -->
        <rect x="0" y="19" width="5" height="1" fill="#777"/>
        <!-- Prongs (three tines) -->
        <rect x="0" y="20" width="1" height="1" fill="#999"/>
        <rect x="0" y="21" width="1" height="1" fill="#888"/>
        <rect x="2" y="20" width="1" height="1" fill="#999"/>
        <rect x="2" y="21" width="1" height="1" fill="#888"/>
        <rect x="4" y="20" width="1" height="1" fill="#999"/>
        <rect x="4" y="21" width="1" height="1" fill="#888"/>

        <!-- === OVERALLS === -->
        <rect x="7" y="12" width="6" height="1" fill="#4466AA"/>
        <rect x="7" y="13" width="6" height="1" fill="#3355AA"/>
        <rect x="7" y="14" width="6" height="1" fill="#4466AA"/>
        <rect x="7" y="15" width="6" height="1" fill="#3355AA"/>
        <!-- Strap -->
        <rect x="8" y="11" width="1" height="1" fill="#4466AA"/>
        <!-- Pocket -->
        <rect x="8" y="13" width="2" height="1" fill="#2244AA"/>
      </g>

      <!-- === LEGS === -->
      <g id="leg-right" class="leg-right">
        <rect x="9" y="16" width="4" height="1" fill="#3355AA"/>
        <rect x="9" y="17" width="4" height="1" fill="#4466AA"/>
        <rect x="9" y="18" width="4" height="1" fill="#3355AA"/>
        <rect x="9" y="19" width="4" height="1" fill="#3355AA"/>
        <rect x="8" y="20" width="5" height="1" fill="#555"/>
        <rect x="7" y="21" width="6" height="1" fill="#444"/>
      </g>

      <g id="leg-left" class="leg-left">
        <rect x="7" y="16" width="4" height="1" fill="#4466AA"/>
        <rect x="7" y="17" width="4" height="1" fill="#3355AA"/>
        <rect x="7" y="18" width="4" height="1" fill="#4466AA"/>
        <rect x="7" y="19" width="4" height="1" fill="#3355AA"/>
        <rect x="6" y="20" width="5" height="1" fill="#555"/>
        <rect x="5" y="21" width="6" height="1" fill="#444"/>
      </g>
    </svg>
  </div>
</div>

<style>
  .farmer-intro {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: var(--color-bg, #fafafa);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    overflow: hidden;
    transition: opacity 0.6s ease;
  }

  .farmer-intro.fade-out {
    opacity: 0;
    pointer-events: none;
  }

  .farmer {
    position: absolute;
    right: -130px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 112px;
    height: 144px;
    image-rendering: pixelated;
  }

  .farmer svg {
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
  }

  /* === WALK === */
  .farmer.walking {
    animation: walkIn 3s ease-out forwards;
  }

  .farmer.walking .leg-left {
    animation: legFront 0.35s steps(1) infinite;
  }

  .farmer.walking .leg-right {
    animation: legBack 0.35s steps(1) infinite;
  }

  @keyframes legFront {
    0%   { transform: translateX(2px); }
    50%  { transform: translateX(-2px); }
  }

  @keyframes legBack {
    0%   { transform: translateX(-2px); }
    50%  { transform: translateX(2px); }
  }

  @keyframes walkIn {
    0%   { right: -130px; }
    100% { right: calc(50% - 56px); }
  }

  /* === AT CENTER === */
  .farmer.at-center {
    animation: none;
    right: auto;
    left: 50%;
    transform: translateX(-50%) translateY(-50%);
  }

  .farmer.at-center .leg-left,
  .farmer.at-center .leg-right {
    animation: none;
    transform: none;
  }

  /* === LOOKING RIGHT (flipped profile) === */
  .farmer.looking-right {
    animation: none;
    right: auto;
    left: 50%;
    transform: translateX(-50%) translateY(-50%) scaleX(-1);
  }

  .farmer.looking-right .leg-left,
  .farmer.looking-right .leg-right {
    animation: none;
    transform: none;
  }

  /* === FACING USER (front-on, squished to suggest facing camera) === */
  .farmer.facing {
    animation: none;
    right: auto;
    left: 50%;
    transform: translateX(-50%) translateY(-50%) scaleX(0.7);
  }

  .farmer.facing .leg-left,
  .farmer.facing .leg-right {
    animation: none;
    transform: none;
  }

  /* === JUMP === */
  .farmer.jumping {
    right: auto;
    left: 50%;
    animation: jump 0.9s cubic-bezier(0.4, 0, 1, 1) forwards;
  }

  .farmer.jumping .leg-left,
  .farmer.jumping .leg-right {
    animation: none;
    transform: none;
  }

  @keyframes jump {
    0% {
      transform: translateX(-50%) translateY(-50%) scaleX(0.7);
      opacity: 1;
    }
    25% {
      transform: translateX(-50%) translateY(calc(-50% - 100px)) scaleX(0.7);
      opacity: 1;
    }
    100% {
      transform: translateX(-50%) translateY(100vh) scaleX(0.7);
      opacity: 0;
    }
  }
</style>

<script>
  const farmer = document.getElementById('farmer');
  const intro = document.getElementById('farmer-intro');

  if (farmer && intro && !sessionStorage.getItem('knight-intro-seen')) {
    sessionStorage.setItem('knight-intro-seen', 'true');

    // Step 1: Walk in from right (profile facing left)
    setTimeout(() => farmer.classList.add('walking'), 300);

    // Step 2: Arrive at center, stop (still facing left)
    setTimeout(() => {
      farmer.classList.remove('walking');
      farmer.classList.add('at-center');
    }, 3300);

    // Step 3: Look right (flip profile)
    setTimeout(() => {
      farmer.classList.remove('at-center');
      farmer.classList.add('looking-right');
    }, 3900);

    // Step 4: Turn to face the user (front-on)
    setTimeout(() => {
      farmer.classList.remove('looking-right');
      farmer.classList.add('facing');
    }, 4500);

    // Step 5: Jump up and fall off screen
    setTimeout(() => {
      farmer.classList.remove('facing');
      farmer.classList.add('jumping');
    }, 5200);

    // Step 6: Fade out intro
    setTimeout(() => intro.classList.add('fade-out'), 5700);

    // Step 7: Remove from DOM
    setTimeout(() => intro.remove(), 6300);

  } else if (intro) {
    intro.remove();
  }
</script>
